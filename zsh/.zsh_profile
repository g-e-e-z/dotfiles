export XDG_CONFIG_HOME=$HOME/.config
VIM="nvim"

PERSONAL=$XDG_CONFIG_HOME/personal
source $PERSONAL/env
for i in `find -L $PERSONAL`; do
    source $i
done

export GOPATH=$HOME/go

addToPathFront() {
    if [[ "$PATH" != *"$1"* ]]; then
        export PATH=$1:$PATH
    fi
}

addToPathFront $HOME/go/bin
addToPathFront $HOME/personal/sumneko/bin

# open "https:www.reddit.com$(curl -sA 'Reddit CLI' "https://www.reddit.com/r/neovim/new.json?limit=10" | jq -r '.data.children | .[] | "\(.data.title)\t\(.data.permalink)"' | fzf --delimiter='\t' --with-nth=1 | cut -f2)"
reddit() {
    local json
    local url
    json=$(curl -sA 'Reddit CLI' "https://www.reddit.com/r/$1/new.json?limit=10" | jq -r '.data.children | .[] | "\(.data.title)\t\(.data.permalink)"')
    url=$(echo "$json" | fzf --delimiter='\t' --with-nth=1 --reverse | cut -f2)
    if [[ -n $url ]]
    then
        open "https://www.reddit.com$url"
    fi
}

